NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/espaco_empreendedor?schema=public"

JWT_SECRET=troque_este_segredo_em_producao
JWT_EXPIRES_IN=1d

# Frontend autorizado a chamar a API
CORS_ORIGIN=http://localhost:3001

# Rate limit — solicitações públicas
THROTTLE_TTL=60
THROTTLE_LIMIT=5

# Storage de relatórios
# local para desenvolvimento; r2 para deploy em nuvem
REPORT_STORAGE_DRIVER=local
REPORT_STORAGE_DIR=./storage/reports

# Cloudflare R2 (usar quando REPORT_STORAGE_DRIVER=r2)
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# E-mail
# smtp para dev/local; resend para deploy gratuito; disabled para desligar
MAIL_PROVIDER=smtp
MAIL_FROM="Espaco Empreendedor <noreply@espaco.com>"

# Resend (usar quando MAIL_PROVIDER=resend)
RESEND_API_KEY=

# SMTP (opcional para desenvolvimento local)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
